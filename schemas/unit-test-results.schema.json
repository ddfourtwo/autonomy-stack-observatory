{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unit Test Results",
  "description": "Unit/integration test results with optional coverage",
  "type": "object",
  "required": ["vertical", "source", "timestamp", "summary", "entries"],
  "properties": {
    "vertical": { "type": "string" },
    "source": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed"],
      "properties": {
        "total": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer", "default": 0 },
        "coverage_percent": { "type": ["number", "null"] },
        "duration_seconds": { "type": "number" }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "module", "status"],
        "properties": {
          "name": { "type": "string" },
          "module": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
          "duration_seconds": { "type": "number" },
          "error": { "type": ["string", "null"] }
        }
      }
    }
  }
}
