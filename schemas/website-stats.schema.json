{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Website Stats",
  "description": "Website traffic and engagement metrics",
  "type": "object",
  "required": ["vertical", "source", "timestamp", "summary", "entries"],
  "properties": {
    "vertical": { "type": "string", "enum": ["website"] },
    "source": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "summary": {
      "type": "object",
      "required": ["pageviews_24h", "unique_visitors_24h"],
      "properties": {
        "pageviews_24h": { "type": "integer" },
        "unique_visitors_24h": { "type": "integer" },
        "avg_session_duration_seconds": { "type": "number" },
        "bounce_rate": { "type": "number" }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "pageviews"],
        "properties": {
          "path": { "type": "string" },
          "pageviews": { "type": "integer" },
          "unique_visitors": { "type": "integer" }
        }
      }
    }
  }
}
