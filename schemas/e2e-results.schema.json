{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "E2E Test Results",
  "description": "End-to-end test results with optional screenshot/video proof",
  "type": "object",
  "required": ["vertical", "source", "timestamp", "summary", "entries"],
  "properties": {
    "vertical": { "type": "string", "enum": ["product"] },
    "source": { "type": "string", "enum": ["e2e-ios", "e2e-web"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed"],
      "properties": {
        "total": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "errors": { "type": "integer", "default": 0 },
        "skipped": { "type": "integer", "default": 0 },
        "duration_seconds": { "type": "number" }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "suite", "status"],
        "properties": {
          "name": { "type": "string" },
          "suite": { "type": "string", "description": "Test group/screen (e.g. 'Authentication', 'Workouts')" },
          "description": { "type": ["string", "null"], "description": "Human-readable description of what the test verifies" },
          "status": { "type": "string", "enum": ["passed", "failed", "error", "skipped"] },
          "duration_seconds": { "type": "number" },
          "screenshot_url": { "type": ["string", "null"], "description": "/media/ path to screenshot in R2" },
          "video_url": { "type": ["string", "null"], "description": "/media/ path to video in R2" },
          "error": { "type": ["string", "null"] }
        }
      }
    }
  }
}
